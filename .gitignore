# =============================================================================
# Repository .gitignore
# =============================================================================

# --- Secrets / Environment ---
.env
.env.*
!.env.example
*.env
!*.env.example

# Tokens and credentials
*token.json*
*credentials.json*
*.pem

# --- Node / Frontend ---
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Build output ---
build/
dist/
.next/
.cache/
.parcel-cache/
.vercel
.netlify

# --- Coverage / Tests ---
/coverage
test_reports/

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Logs & debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dump.rdb

# --- OS ---
.DS_Store
Thumbs.db

# --- Archives / large assets (avoid bloat) ---
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# --- Emergent platform internals (not relevant to GitHub) ---
.emergent/
memory/
test_result.md
backend_test.py

# --- Misc ---
chainlit.md
.chainlit
.ipynb_checkpoints/
android-sdk/
-e 
# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials
