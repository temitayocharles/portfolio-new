# =============================================================================
# Repository .gitignore
# =============================================================================

# Secrets and environment files
.env
.env.*
*.env
!.env.example
!*.env.example
*token.json*
*credentials.json*
credentials.json
*.pem
*.key
.credentials

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/

# Node and frontend
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs and platform caches
build/
dist/
frontend/build/
frontend/dist/
.next/
.cache/
.parcel-cache/
.vercel/
.netlify/

# Coverage and test artifacts
coverage/
test_reports/

# Logs and debug output
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
dump.rdb

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
.ipynb_checkpoints/

# Operating system files
.DS_Store
Thumbs.db

# Archives and large local assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Local platform internals
.emergent/
memory/
.chainlit
chainlit.md
android-sdk/
